<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="StepUnlock"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:text="Lock your screen on a timer. Walk to unlock."
            android:textSize="15sp"
            android:textColor="#888888"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"/>

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:text="STATUS"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/statusText"
                android:text="Inactive — tap Enable Admin to start"
                android:textSize="15sp"
                android:textColor="#E24B4A"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/enableButton"
                android:text="Enable Admin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="#1A1A1A"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Settings card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:text="SETTINGS"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"/>

            <TextView
                android:text="Steps required to unlock"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:text="How many steps you must walk before unlocking"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/stepInput"
                android:inputType="number"
                android:hint="e.g. 20"
                android:textSize="16sp"
                android:padding="14dp"
                android:background="#F3F2EF"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="22dp"/>

            <TextView
                android:text="Lock after (minutes of continuous screen use)"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:text="Timer resets when you turn the screen off yourself"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/timeInput"
                android:inputType="number"
                android:hint="e.g. 30"
                android:textSize="16sp"
                android:padding="14dp"
                android:background="#F3F2EF"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="18dp"/>

            <Button
                android:id="@+id/saveButton"
                android:text="Save Settings"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="#378ADD"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- How it works -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:text="HOW IT WORKS"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:text="1.  Tap Enable Admin and grant the permission"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:text="2.  Set your step goal and time limit, then tap Save"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:text="3.  After your time limit, the screen locks automatically"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:text="4.  Walk your required steps to unlock"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
